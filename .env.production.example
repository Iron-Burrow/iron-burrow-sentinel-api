NODE_ENV=production
PORT=3000

POSTGRES_DB=iron_burrow_sentinel
POSTGRES_USER=iron_burrow_sentinel
POSTGRES_PASSWORD=replace-with-a-long-random-password
DATABASE_URL=postgresql://iron_burrow_sentinel:replace-with-a-long-random-password@postgres:5432/iron_burrow_sentinel

API_KEY_HASH_SECRET=replace-with-at-least-32-random-bytes
SESSION_SECRET=replace-with-at-least-32-random-bytes

RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_COST_UNITS=600

PRICE_BACKEND=disabled
PRICE_QL_BASE_URL=
PRICE_QL_INTERNAL_TOKEN=
PRICE_SERVICE_TIMEOUT_MS=3000
PRICE_SERIES_DEFAULT_RANGE=7d
